local function hasTracker(player)
    for _, child in ipairs(player:GetChildren()) do
        if typeof(child.Name)=="string" and string.sub(child.Name,-8)=="Tracker$" then
            local n=string.sub(child.Name,1,-9)
            if Players:FindFirstChild(n) then return true,n end
        end
    end
    return false,nil
end

local function isStaff(player)
    if not player or not player:IsA("Player") then return false end
    if staffPlayers.groups then
        for gid, roles in pairs(staffPlayers.groups) do
            local ok,rank=pcall(function() return player:GetRankInGroup(gid) end)
            if ok and rank and rank>0 then
                local ok2,role=pcall(function() return player:GetRoleInGroup(gid) end)
                if ok2 and role and roles[role] then return true,role,gid end
            end
        end
    end
    if staffPlayers.users then
        for _,uid in ipairs(staffPlayers.users) do
            if player.UserId==uid then return true,"UserID",uid end
        end
    end
    return false
end

local function checkCurrentStaff()
    for _,player in ipairs(Players:GetPlayers()) do
        if player==me then continue end
        local found,role=isStaff(player)
        local tracked=hasTracker(player)
        if found or tracked then
            me:Kick("Staff detected: "..player.Name..(role and " ("..tostring(role)..")" or ""))
            return true
        end
    end
    return false
end

local function onPlayerJoining(player)
