local XMHH1 = ReplicatedStorage:WaitForChild("Events"):WaitForChild("XMHH.2")
local XMHH2 = ReplicatedStorage:WaitForChild("Events"):WaitForChild("XMHH2.2")

local ValidMeleeParts = {"Head","Torso","Left Arm","Right Arm","Left Leg","Right Leg"}

local MeleeAura = {
    Enabled     = false,
    Distance    = 12,
    TeamCheck   = false,
    CheckDowned = false,
    ShowAnim    = true,
    TargetPart  = "Head",
}

local FinishAura = {
    Enabled  = false,
    Distance = 12,
