-- // Wallbang
local WallbangEnabled = false
local WallbangHooked  = false
local WallbangOldFunc = nil

local function EnableWallbang()
    if WallbangHooked then return end
    pcall(function()
        local rs = game:GetService("ReplicatedStorage")
        local fastcast = (rs:FindFirstChild("Modules") and rs.Modules:FindFirstChild("FastCastRedux"))
            or rs.NewModules.Shared.Services.FastCastRedux
        WallbangOldFunc = require(fastcast).FireWithBlacklist
        require(fastcast).FireWithBlacklist = function(self, ...)
            local args = {...}
            if args[1] and args[1].fc and args[1].fc[1] then
                table.insert(args[5], workspace.Map)
            end
            return WallbangOldFunc(self, unpack(args))
        end
        WallbangHooked = true
    end)
end

local function DisableWallbang()
    if not WallbangHooked or not WallbangOldFunc then return end
    pcall(function()
        local rs = game:GetService("ReplicatedStorage")
        local fastcast = (rs:FindFirstChild("Modules") and rs.Modules:FindFirstChild("FastCastRedux"))
            or rs.NewModules.Shared.Services.FastCastRedux
        require(fastcast).FireWithBlacklist = WallbangOldFunc
        WallbangHooked = false
    end)
end

