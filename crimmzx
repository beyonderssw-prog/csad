local BredMakurz_Enabled = false
local bredMakurzConnection = nil

local function formatSafeName(name)
    if not name then return "" end
    name = string.gsub(name, "([a-z])([A-Z])", "%1 %2")
    local underscoreIndex = string.find(name, "_")
    if underscoreIndex then name = string.sub(name, 1, underscoreIndex-1) end
    return name
end

local function GetBredMakurzFolder()
    local folder = workspace:FindFirstChild("BredMakurz", true)
    if not folder then
        local map = workspace:FindFirstChild("Map")
        folder = map and map:FindFirstChild("BredMakurz", true)
    end
    return folder
end

local function ApplySafeESP()
    local folder = GetBredMakurzFolder()
    if not folder or not BredMakurz_Enabled then return end
    local hrp = me.Character and me.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    for _, v in pairs(folder:GetChildren()) do
        local pos = (v:IsA("Model") and v.PrimaryPart and v.PrimaryPart.Position)
            or (v:IsA("BasePart") and v.Position)
        if not pos then local p = v:FindFirstChildOfClass("BasePart"); if p then pos = p.Position end end
        if pos then
            local distance = (pos - hrp.Position).Magnitude
            local existingGui = v:FindFirstChild("Ahh")
            if distance <= 1000 then
                if not existingGui then
                    local x = Instance.new("BillboardGui", v)
                    x.Name="Ahh"; x.AlwaysOnTop=true; x.Size=UDim2.new(5,0,2,0); x.MaxDistance=600
                    local label = Instance.new("TextLabel", x)
                    label.Size=UDim2.new(1,0,1,0); label.BackgroundTransparency=1
                    label.Font=Enum.Font.GothamBold; label.TextSize=14; label.TextStrokeTransparency=0.3
                    label.Text=formatSafeName(v.Name); x.Adornee=v
                    local val = v:FindFirstChild("Values") and v.Values:FindFirstChild("Broken")
                    local function Update()
                        if label and label.Parent then
                            label.TextColor3 = (val and val.Value==true) and Color3.new(1,0,0) or Color3.new(0,1,0)
                        end
                    end
                    if val then Update(); val.Changed:Connect(Update) else label.TextColor3=Color3.new(0,1,0) end
                end
            elseif existingGui then existingGui:Destroy() end
        end
    end
end

local function SafeESP_Toggle(state)
    BredMakurz_Enabled = state
    if state then
        if bredMakurzConnection then bredMakurzConnection:Disconnect() end
        bredMakurzConnection = RunService.Heartbeat:Connect(ApplySafeESP)
    else
        if bredMakurzConnection then bredMakurzConnection:Disconnect(); bredMakurzConnection=nil end
        local f = GetBredMakurzFolder()
        if f then for _,v in pairs(f:GetChildren()) do if v:FindFirstChild("Ahh") then v.Ahh:Destroy() end end end
    end
end

