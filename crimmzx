    TargetPart = "Head",
}

-- // Tool-specific cooldowns
local AttachCD = {
    Fists=0.05, Knuckledusters=0.05, Nunchucks=0.05, Shiv=0.05,
    Bat=1, ["Metal-Bat"]=1, Chainsaw=2.5, Balisong=0.05,
    Rambo=0.3, Shovel=3, Sledgehammer=2, Katana=0.1, Wrench=0.1,
    ["Fire-Axe"]=2.6,
}

local meleeAttachTick = 0
local finishAttachTick = 0

local function MeleeAttack(target, partName, invokeCode)
    if not (target and target:FindFirstChild("Head")) then return end
    local mychar = me.Character
    if not mychar then return end
    local TOOL = mychar:FindFirstChildOfClass("Tool")
    if not TOOL then return end

    local attachcd = AttachCD[TOOL.Name] or 0.5
    local now = tick()
    if invokeCode == "EXECQX" then
        if now - finishAttachTick < attachcd then return end
        finishAttachTick = now
    else
        if now - meleeAttachTick < attachcd then return end
        meleeAttachTick = now
    end

    local ok, val = pcall(function()
        if invokeCode == "EXECQX" then
            return XMHH1:InvokeServer("🍞", tick(), TOOL, invokeCode)
        else
            return XMHH1:InvokeServer("🍞", tick(), TOOL, invokeCode, "Normal", tick(), true)
        end
    end)
    if not ok or val == nil then return end

    -- // Show anim (So it looks somewhat legit
    if MeleeAura.ShowAnim and invokeCode ~= "EXECQX" then
        pcall(function()
            local AnimFolder = TOOL:FindFirstChild("AnimsFolder")
            if not AnimFolder then return end
            local anim = AnimFolder:FindFirstChild("Slash1") or AnimFolder:FindFirstChild("Slash")
            if not anim then return end
            local Animator = mychar:FindFirstChildOfClass("Humanoid") and mychar:FindFirstChildOfClass("Humanoid"):FindFirstChild("Animator")
            if not Animator then return end
            local load = Animator:LoadAnimation(anim)
            load:Play(); load:AdjustSpeed(1.3)
        end)
    end

    task.wait(invokeCode == "EXECQX" and 0.05 or (0.3 + math.random() * 0.2))

    if not mychar.Parent or me.Character ~= mychar then return end
    local myHRP = mychar:FindFirstChild("HumanoidRootPart")
    if not myHRP then return end
    local Handle = TOOL:FindFirstChild("WeaponHandle")
        or TOOL:FindFirstChild("Handle")
        or mychar:FindFirstChild("Right Arm")
    local hitPart = target:FindFirstChild(partName) or target:FindFirstChild("Head")
    if not Handle or not hitPart then return end

    pcall(function()
        if TOOL.Name == "Chainsaw" then
            for i = 1, 15 do
                XMHH2:FireServer("🍞", tick(), TOOL, "2389ZFX34", val, true,
                    Handle, hitPart, target, myHRP.Position, hitPart.Position)
            end
        else
            XMHH2:FireServer("🍞", tick(), TOOL, "2389ZFX34", val, true,
                Handle, hitPart, target, myHRP.Position, hitPart.Position)
        end
    end)
end

-- // More Melee Aura loop
local meleeConn      = nil
local meleeAttacking = false
local function StartMeleeAura()
    if meleeConn then meleeConn:Disconnect() end
    meleeConn = RunService.Heartbeat:Connect(function()
        if not MeleeAura.Enabled then return end
        if meleeAttacking then return end
        local mychar = me.Character
        if not mychar then return end
        local myHRP = mychar:FindFirstChild("HumanoidRootPart")
        if not myHRP then return end
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr == me then continue end
            local char = plr.Character
            if not char then continue end
            local hrp = char:FindFirstChild("HumanoidRootPart")
            local hum = char:FindFirstChildOfClass("Humanoid")
            if not hrp or not hum then continue end
            if hum.Health <= 0 or hum.Health < 15 then continue end
            if char:FindFirstChildOfClass("ForceField") then continue end
            if GlobalWhiteList[plr.Name] then continue end
            if next(GlobalTarget) ~= nil and not GlobalTarget[plr.Name] then continue end
            if MeleeAura.TeamCheck and plr.Team == me.Team then continue end
            if MeleeAura.CheckDowned then
                local ok, downed = pcall(function() return ReplicatedStorage.CharStats[plr.Name].Downed.Value end)
                if ok and downed then continue end
            end
            local dist = (myHRP.Position - hrp.Position).Magnitude
            if dist > MeleeAura.Distance then continue end
            local partName = MeleeAura.TargetPart == "Random"
                and ValidMeleeParts[math.random(1,#ValidMeleeParts)]
                or  MeleeAura.TargetPart
            meleeAttacking = true
            task.spawn(function()
                MeleeAttack(char, partName, "43TRFWX")
                meleeAttacking = false
            end)
            return
        end
    end)
end

local finishConn      = nil
local finishAttacking = false
local function StartFinishAura()
    if finishConn then finishConn:Disconnect() end
    finishConn = RunService.Heartbeat:Connect(function()
        if not FinishAura.Enabled then return end
        if finishAttacking then return end
        local mychar = me.Character
        if not mychar then return end
        local myHRP = mychar:FindFirstChild("HumanoidRootPart")
        if not myHRP then return end
        local TOOL = mychar:FindFirstChildOfClass("Tool")
        if not TOOL then return end

        -- // Finds closest downed player
        local closest, closestDist = nil, FinishAura.Distance
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr == me then continue end
            local char = plr.Character
            if not char then continue end
            local hrp = char:FindFirstChild("HumanoidRootPart")
            local hum = char:FindFirstChildOfClass("Humanoid")
            if not hrp or not hum then continue end
            if hum.Health <= 0 or hum.Health >= 15 then continue end  -- only downed
            if char:FindFirstChildOfClass("ForceField") then continue end
            if GlobalWhiteList[plr.Name] then continue end
            if next(GlobalTarget) ~= nil and not GlobalTarget[plr.Name] then continue end
            if FinishAura.TeamCheck and plr.Team == me.Team then continue end
            local dist = (myHRP.Position - hrp.Position).Magnitude
            if dist < closestDist then closest = char; closestDist = dist end
        end

        if not closest then return end

        -- Uses Right Leg as hit part
        local hitPart = closest:FindFirstChild("Right Leg")
            or closest:FindFirstChild("RightLowerLeg")
            or closest:FindFirstChild("Head")
        if not hitPart then return end

        finishAttacking = true
        task.spawn(function()
            -- // Execute remote ezeezez
            local ok, val = pcall(function()
                return XMHH1:InvokeServer("🍞", tick(), TOOL, "EXECQX")
            end)
            if ok and val ~= nil then
                local Handle = TOOL:FindFirstChild("WeaponHandle")
                    or TOOL:FindFirstChild("Handle")
                    or mychar:FindFirstChild("Right Arm")
                if Handle then
                    task.wait(0.3 + math.random() * 0.2)
                    if mychar.Parent and me.Character == mychar then
                        pcall(function()
                            XMHH2:FireServer("🍞", tick(), TOOL, "2389ZFX34", val, true,
                                Handle, hitPart, closest, myHRP.Position, hitPart.Position)
                        end)
                    end
                end
            end
            finishAttacking = false
        end)
    end)
end

