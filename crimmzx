local WhitelistChams = {}
local TargetChams    = {}

local function applyChams(player, color, storage)
    if not player or not player.Character then return end
    -- remove old if exists
    if storage[player.Name] then
        storage[player.Name]:Destroy()
        storage[player.Name] = nil
    end
    local h = Instance.new("Highlight")
    h.FillColor          = color
    h.OutlineColor       = color
    h.FillTransparency   = 0.5
    h.OutlineTransparency= 0
    h.DepthMode          = Enum.HighlightDepthMode.AlwaysOnTop
    h.Adornee            = player.Character
    h.Parent             = player.Character
    storage[player.Name] = h
end

local function removeChams(playerName, storage)
    if storage[playerName] then
        storage[playerName]:Destroy()
        storage[playerName] = nil
    end
end

local function refreshAllChams()
    -- whitelist = green
    for name, _ in pairs(GlobalWhiteList) do
        local p = Players:FindFirstChild(name)
        if p then applyChams(p, Color3.fromRGB(0,255,0), WhitelistChams) end
    end
    -- targets = red
    for name, _ in pairs(GlobalTarget) do
        local p = Players:FindFirstChild(name)
        if p then applyChams(p, Color3.fromRGB(255,0,0), TargetChams) end
    end
end

local function getPlayerNames()
