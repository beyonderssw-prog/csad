-- // Scrap ESP
local function ScrapESP(Scrap)
    local ItemName    = Drawing.new("Text"); ItemName.Visible=false;    ItemName.Center=true;  ItemName.Outline=true; ItemName.Font=2; ItemName.Size=13; ItemName.Color=Color3.new(1,2.5,2.5); ItemName.Text="Scrap"
    local RarityText  = Drawing.new("Text"); RarityText.Visible=false;  RarityText.Center=true; RarityText.Outline=true; RarityText.Font=2; RarityText.Size=13; RarityText.Color=Color3.new(1,2.5,2.5); RarityText.Text="Type"
    local DistText    = Drawing.new("Text"); DistText.Visible=false;    DistText.Center=true;  DistText.Outline=true;  DistText.Font=2; DistText.Size=13; DistText.Color=Color3.new(1,2.5,2.5);   DistText.Text="Distance"
    coroutine.wrap(function()
        local Iu; Iu = RunService.RenderStepped:Connect(function()
            if not workspace:IsAncestorOf(Scrap) then
                ItemName.Visible=false; RarityText.Visible=false; DistText.Visible=false; Iu:Disconnect(); return
            end
            local mp = Scrap:FindFirstChild("MeshPart"); if not mp then return end
            local Vec, OnScreen = camera:WorldToViewportPoint(mp.Position)
            if not OnScreen then ItemName.Visible=false; RarityText.Visible=false; DistText.Visible=false; return end
            local dist = math.ceil((mp.Position - me.Character:WaitForChild("HumanoidRootPart").Position).Magnitude)
            ItemName.Position   = Vector2.new(Vec.X, Vec.Y-30)
            RarityText.Position = Vector2.new(Vec.X, Vec.Y-20)
            DistText.Position   = Vector2.new(Vec.X, Vec.Y-10)
            if ESPSettings.ScrapESP.Enabled and dist < ESPSettings.ScrapESP.Distance then
                local particle = mp:FindFirstChild("Particle")
                local col = particle and tostring(particle.Color) or ""
                local show = false
                if col == "0 1 1 1 0 1 1 1 1 0 " then
                    RarityText.Text="Rarity: Bad"; RarityText.Color=Color3.new(1,2.5,2.5)
                    show = ESPSettings.ScrapESP.BadOnly
                elseif col == "0 0.184314 1 0.4 0 1 0.184314 1 0.4 0 " then
                    RarityText.Text="Rarity: Good"; RarityText.Color=Color3.new(0,2.5,0)
                    show = ESPSettings.ScrapESP.GoodOnly
                elseif col == "0 1 0.184314 0.184314 0 1 1 0.184314 0.184314 0 " then
                    RarityText.Text="Rarity: Rare"; RarityText.Color=Color3.new(1,0,0)
                    show = ESPSettings.ScrapESP.RareOnly
                else
                    RarityText.Text="Rarity: Legendary"; RarityText.Color=Color3.new(1,1,0.5)
                    show = ESPSettings.ScrapESP.LegendaryOnly
                end
                DistText.Text = "["..dist.."]"
                ItemName.Visible=show; RarityText.Visible=show; DistText.Visible=show
            else
                ItemName.Visible=false; RarityText.Visible=false; DistText.Visible=false
                if not ESPSettings.ScrapESP.Enabled then Iu:Disconnect() end
            end
        end)
    end)()
end

