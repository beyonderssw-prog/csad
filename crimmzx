-- DownedCheck 
local function DownedCheck(Character)
    local PlayerName = Character.Name
    local charStats = game:GetService("ReplicatedStorage"):FindFirstChild("CharStats")
    if not charStats or not charStats:FindFirstChild(PlayerName) then return false end
    local downed = charStats[PlayerName]:FindFirstChild("Downed") and charStats[PlayerName].Downed.Value or false
    local hum    = Character:FindFirstChildOfClass("Humanoid")
    local health = hum and hum.Health or 100
    return downed or health <= 15
end

